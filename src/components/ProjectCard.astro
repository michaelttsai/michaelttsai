---
interface Props {
  title: string;
  description: string;
  tags: string[];
  status: 'completed' | 'in-progress' | 'planned';
  link?: string;
}

const { title, description, tags, status, link } = Astro.props;

const statusLabel = {
  'completed': 'Completed',
  'in-progress': 'In progress',
  'planned': 'Planned',
};

const statusClass = {
  'completed': 'status-completed',
  'in-progress': 'status-in-progress',
  'planned': 'status-planned',
};
---

<article class="project-card">
  <div class="project-header">
    <h3>{title}</h3>
    <span class:list={['status-badge', statusClass[status]]}>
      {statusLabel[status]}
    </span>
  </div>
  <p>{description}</p>
  <div class="project-footer">
    <div class="tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
    {link && (
      <a href={link} target="_blank" rel="noopener" class="project-link">
        View &rarr;
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .project-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 12px rgba(37, 99, 235, 0.08);
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .project-header h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .status-badge {
    font-size: 0.72rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .status-completed {
    background: #dcfce7;
    color: #166534;
  }

  .status-in-progress {
    background: #fef3c7;
    color: #92400e;
  }

  .status-planned {
    background: #f1f5f9;
    color: #64748b;
  }

  p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .project-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--color-tag-bg);
    color: var(--color-accent);
    font-size: 0.75rem;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-weight: 500;
  }

  .project-link {
    font-size: 0.9rem;
    font-weight: 500;
  }
</style>
