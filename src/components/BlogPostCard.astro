---
interface Props {
  title: string;
  description: string;
  date: string;
  tags?: string[];
  slug: string;
}

const { title, description, date, tags = [], slug } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="post-card-link">
    <time datetime={date}>{formattedDate}</time>
    <h3>{title}</h3>
    <p>{description}</p>
    {tags.length > 0 && (
      <div class="tags">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
  </a>
</article>

<style>
  .post-card {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .post-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .post-card-link {
    display: block;
    padding: 1.5rem;
    color: inherit;
  }

  .post-card-link time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .post-card-link h3 {
    font-size: 1.25rem;
    margin: 0.5rem 0;
    color: var(--color-text);
    transition: color 0.2s;
  }

  .post-card:hover h3 {
    color: var(--color-accent);
  }

  .post-card-link p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--color-tag-bg);
    color: var(--color-accent);
    font-size: 0.78rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-weight: 500;
  }
</style>
