---
const navItems = [
  { label: 'Blog', href: '/blog' },
  { label: 'Projects', href: '/projects' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav class="container nav-container">
    <a href="/" class="logo">
      <span class="logo-icon">&#9670;</span> michael tsai
    </a>
    <ul class="nav-links">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[{ active: currentPath.startsWith(item.href) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo:hover { color: var(--color-accent); }

  .logo-icon {
    color: var(--color-accent);
    font-size: 1.4rem;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: 0.95rem;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
</style>
