---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p>&copy; {year} Michael Tsai. Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>.</p>
    <div class="footer-links">
      <a href="https://github.com" target="_blank" rel="noopener" aria-label="GitHub">GitHub</a>
      <a href="/rss.xml" aria-label="RSS Feed">RSS</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
</style>
