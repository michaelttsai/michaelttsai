---
import BaseLayout from './BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;

const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="blog-post">
    <header class="post-header">
      <time datetime={frontmatter.date}>{formattedDate}</time>
      <h1>{frontmatter.title}</h1>
      <p class="post-description">{frontmatter.description}</p>
      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="post-tags">
          {frontmatter.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <hr class="post-divider" />

    <!-- Comments placeholder: replace with Giscus script -->
    <section class="comments-placeholder" id="comments">
      <h2>Comments</h2>
      <p>
        Comments powered by <a href="https://giscus.app" target="_blank" rel="noopener">Giscus</a>
        will appear here. Follow the
        <a href="https://giscus.app" target="_blank" rel="noopener">setup guide</a>
        to connect your GitHub repo.
      </p>
      <!--
        After setup, paste your Giscus script tag here:
        <script src="https://giscus.app/client.js"
          data-repo="YOUR_USERNAME/YOUR_REPO"
          data-repo-id="..."
          data-category="Announcements"
          data-category-id="..."
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="top"
          data-theme="light"
          data-lang="en"
          crossorigin="anonymous"
          async>
        </script>
      -->
    </section>

    <NewsletterSignup />
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-header time {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .post-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0.5rem 0;
    line-height: 1.2;
  }

  .post-description {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--color-tag-bg);
    color: var(--color-accent);
    font-size: 0.8rem;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-weight: 500;
  }

  .post-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0 2rem;
  }

  .comments-placeholder {
    background: var(--color-bg-card);
    border: 1px dashed var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    color: var(--color-text-muted);
  }

  .comments-placeholder h2 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
</style>
